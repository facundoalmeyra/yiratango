{
  "name": "Follow",
  "type": "object",
  "properties": {
    "artist_id": {
      "type": "string",
      "description": "Reference to the Artist ID"
    },
    "fan_user_id": {
      "type": "string",
      "description": "The user ID (email) of the fan following the artist"
    },
    "description": {
      "type": "string",
      "description": "Optional note about this follow relationship",
      "maxLength": 1000
    }
  },
  "required": [
    "artist_id",
    "fan_user_id"
  ]
}